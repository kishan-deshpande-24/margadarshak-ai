PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/margadarshak_db

JWT_SECRET=your_min_32_char_random_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# FREE - Groq API https://console.groq.com 
GROQ_API_KEY=gsk_...

# FREE - Cloudinary https://cloudinary.com 
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# FREE - LiveKit Cloud https://livekit.io 
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_secret

# FREE - Judge0 on RapidAPI https://rapidapi.com/judge0-official/api/judge0-ce 
JUDGE0_API_KEY=your_rapidapi_key
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# FREE - Gmail SMTP (Google Account -> Security -> App Passwords)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=Margadarshak AI <your_gmail@gmail.com>

# FREE - Google OAuth https://console.cloud.google.com 
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

FRONTEND_URL=http://localhost:3000
NODE_ENV=development
